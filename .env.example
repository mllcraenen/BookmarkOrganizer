# Telegram bot token — obtain via @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Your Telegram user ID — get it by messaging @userinfobot
ALLOWED_TELEGRAM_USER_ID=your_user_id_here

# Twitter/X session cookies — extract from browser devtools:
# 1. Open x.com and log in
# 2. Open DevTools → Application → Cookies → https://x.com
# 3. Copy values for 'auth_token' and 'ct0'
X_AUTH_TOKEN=your_auth_token_here
X_SESSION_COOKIE=your_ct0_value_here

# Path to the Obsidian vault (absolute path)
VAULT_PATH=/home/admin/projects/BookmarkOrganizer/vault
